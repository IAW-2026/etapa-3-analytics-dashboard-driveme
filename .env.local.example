# URLs de los microservicios de DriveMe
# Reemplazá con las URLs reales de cada servicio desplegado
RIDER_APP_URL=https://your-rider-app.vercel.app/
DRIVER_APP_URL=https://your-driver-app.vercel.app/
FEEDBACK_APP_URL=https://your-feedback-app.vercel.app/
PAYMENTS_APP_URL=https://your-payments-app.vercel.app/

# Tokens de autenticación entre servicios
# Token que este dashboard envía como x-api-key a rider, driver y feedback
ANALYTICS_DASHBOARD_SECRET=your-analytics-dashboard-secret
# Token que este dashboard envía como Bearer a payments
PAYMENTS_SERVICE_SECRET=your-payments-service-secret

# Clerk — creá una app en https://dashboard.clerk.com y copiá las keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
